# Example server environment configuration
# Copy this to .env and fill in with real values

# Polling interval in milliseconds between full account-loop cycles
# Default: 60000 (1 minute). Recommended minimum: 30000 (30 seconds)
POLL_INTERVAL=60000

# Main account — SCRAP tokens earned by sub-accounts are swept here after each claim.
# Any sub-account whose SCRAP balance exceeds the configured scrapAllowance (default: 200)
# will transfer the surplus to this account automatically.
# Also used as the buyer account for the relic-market-buy script.
# Leave blank to disable SCRAP transfers entirely.
TERRACORE_ACCOUNT_MAIN=your-main-username

# AES encryption key used to decrypt TERRACORE_ACCOUNTS_ENC
TERRACORE_ENCRYPTION_KEY=your-32-char-or-longer-secret-key

# Encrypted accounts JSON — generated with: node server/shared/scripts/encrypt-accounts.mjs
TERRACORE_ACCOUNTS_ENC='{"accounts":[...],"version":"1.0"}'

# ── Relic market buy script (script:relic-market-buy) ─────────────────────────

# Buyer account is resolved from TERRACORE_ACCOUNT_MAIN above.
# All other accounts in TERRACORE_ACCOUNTS_ENC are treated as tracked sellers.

# (Optional) Only buy these rarity types. Omit to buy all rarities.
# RELIC_RARITY_FILTER=epic_relics,legendary_relics

# (Optional) Skip listings priced above this HIVE amount per unit.
# RELIC_MAX_PRICE_PER_UNIT=0.500
